# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore environment files (but keep .env.sample)
/.env
/.env.local
/.env.*.local
/.env.production
/.env.staging
/.env.development

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

# Ignore master key for decrypting credentials and more.
/config/master.key

# Ignore generated database.yml (will be auto-generated from template)
/config/database.yml

# Ignore bin directory (will be auto-generated by rails new)
/bin/

# Ignore backup files
*.backup
*.bak

# Ignore Docker override files
docker-compose.override.yml
.docker/

# Ignore IDE files
.vscode/
.idea/
*.swp
*.swo

# Ignore OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Ignore development artifacts
node_modules/
coverage/
tasks/
